{
  "name": "@code-platform/api-scripts",
  "version": "1.0.0",
  "description": "通用代码仓平台API命令行工具",
  "main": "src/index.js",
  "bin": {
    "platform-api": "./bin/platform-api.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "build": "npm run lint && npm run test"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "commander": "^11.0.0",
    "chalk": "^4.1.2",
    "joi": "^17.11.0",
    "fs-extra": "^11.2.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "nodemon": "^3.0.0"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}